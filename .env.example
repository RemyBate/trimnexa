# Trimnexa environment variables
# Copy to .env and fill in values. Never commit .env files with secrets.

# --- Application (Phase 1A) ---
APP_ENV=development
APP_URL=http://localhost:4321
DEFAULT_LOCALE=en

# --- Database (Phase 3) ---
# Local PostgreSQL example (adjust user, password, host, port, database name):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trimnexa

# --- Authentication (Phase 4) ---
# AUTH_SECRET=
# AUTH_URL=http://localhost:4321

# --- Image storage (Phase 7) ---
# STORAGE_PROVIDER=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_URL=

# --- Payments (Phase 11) ---
# PAYMENT_PROVIDER=
# PAYMENT_API_KEY=
# PAYMENT_WEBHOOK_SECRET=

# --- Marketplace commission (Phase 13) ---
# COMMISSION_RATE=

# --- Email (Phase 16) ---
# EMAIL_PROVIDER=
# EMAIL_API_KEY=
# EMAIL_FROM=

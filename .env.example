# Trimnexa environment variables
# Copy to .env and fill in values. Never commit .env files with secrets.

# --- Application (Phase 1A) ---
APP_ENV=development
# Use one consistent origin locally (do not mix localhost and 127.0.0.1 in the same browser session).
APP_URL=http://127.0.0.1:4321
DEFAULT_LOCALE=en

# --- Database (Phase 3) ---
# MySQL connection string (adjust user, password, host, port, database name):
# Example for local MySQL / XAMPP / Docker:
DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/trimnexa
# If your local MySQL listens on another port (for example 3307 or Docker-mapped 3308):
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3307/trimnexa
# Optional Docker Compose helper: docker compose -f docker-compose.mysql.yml up -d

# --- Authentication (Phase 4) ---
# Generate a secret: npx @better-auth/cli@latest secret
# AUTH_SECRET=
# AUTH_URL=http://127.0.0.1:4321
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://127.0.0.1:4321
# Optional comma-separated extra origins (dev helpers; avoid in production):
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:4321,http://[::1]:4321
# SEED_ADMIN_PASSWORD=ChangeMe123!

# --- Image storage (Phase 7) ---
# STORAGE_PROVIDER=
# STORAGE_BUCKET=
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
# STORAGE_PUBLIC_URL=

# --- Payments (Phase 11) ---
# PAYMENT_PROVIDER=
# PAYMENT_API_KEY=
# PAYMENT_WEBHOOK_SECRET=

# --- Marketplace commission (Phase 13) ---
# COMMISSION_RATE=

# --- Email (Phase 16) ---
# Provider: console (local dev), capture (automated tests), or resend (production)
# EMAIL_PROVIDER=console
# EMAIL_API_KEY=
# EMAIL_FROM="Trimnexa <noreply@yourdomain.com>"

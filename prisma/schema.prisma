// Trimnexa Prisma schema — marketplace foundation + Better Auth (Phase 4) + customer account (Phase 5).
// Full marketplace entities are added in later phases per docs/DATABASE.md.

generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "postgresql"
}

// --- Users and access (auth integration in Phase 4) ---

enum UserStatus {
	ACTIVE
	SUSPENDED
	PENDING_VERIFICATION
}

enum Role {
	CUSTOMER
	SELLER
	ADMINISTRATOR
	STAFF
}

model User {
	id            String     @id @default(cuid())
	name          String?
	email         String     @unique
	emailVerified Boolean    @default(false) @map("email_verified")
	image         String?
	phone         String?
	firstName     String?    @map("first_name")
	lastName      String?    @map("last_name")
	status        UserStatus @default(PENDING_VERIFICATION)
	suspendedAt   DateTime?  @map("suspended_at")
	suspendedReason String?  @map("suspended_reason")
	locale        String     @default("en")
	createdAt     DateTime   @default(now()) @map("created_at")
	updatedAt     DateTime   @updatedAt @map("updated_at")

	sessions        Session[]
	accounts        Account[]
	roles           UserRoleAssignment[]
	customerProfile CustomerProfile?
	sellerProfile   SellerProfile?
	auditLogs       AuditLog[]           @relation("AuditActor")
	addresses       CustomerAddress[]
	orders          CustomerOrder[]
	notifications   Notification[]
	supportTickets       SupportTicket[]
	inventoryAdjustments InventoryAdjustment[] @relation("InventoryActor")

	@@map("users")
}

model Session {
	id        String   @id @default(cuid())
	expiresAt DateTime @map("expires_at")
	token     String   @unique
	createdAt DateTime @default(now()) @map("created_at")
	updatedAt DateTime @updatedAt @map("updated_at")
	ipAddress String?  @map("ip_address")
	userAgent String?  @map("user_agent")
	userId    String   @map("user_id")

	user User @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@map("sessions")
}

model Account {
	id                    String    @id @default(cuid())
	accountId             String    @map("account_id")
	providerId            String    @map("provider_id")
	userId                String    @map("user_id")
	accessToken           String?   @map("access_token")
	refreshToken          String?   @map("refresh_token")
	idToken               String?   @map("id_token")
	accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
	refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
	scope                 String?
	password              String?
	createdAt             DateTime  @default(now()) @map("created_at")
	updatedAt             DateTime  @updatedAt @map("updated_at")

	user User @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@map("accounts")
}

model Verification {
	id         String    @id @default(cuid())
	identifier String
	value      String
	expiresAt  DateTime  @map("expires_at")
	createdAt  DateTime? @default(now()) @map("created_at")
	updatedAt  DateTime? @updatedAt @map("updated_at")

	@@map("verifications")
}

model UserRoleAssignment {
	id        String   @id @default(cuid())
	userId    String   @map("user_id")
	role      Role
	grantedAt DateTime @default(now()) @map("granted_at")
	grantedBy String?  @map("granted_by")

	user User @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@unique([userId, role])
	@@map("user_role_assignments")
}

model CustomerProfile {
	id        String   @id @default(cuid())
	userId    String   @unique @map("user_id")
	createdAt DateTime @default(now()) @map("created_at")
	updatedAt DateTime @updatedAt @map("updated_at")

	user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
	wishlist Wishlist?

	@@map("customer_profiles")
}

// --- Customer account (Phase 5) ---

model CustomerAddress {
	id            String   @id @default(cuid())
	userId        String   @map("user_id")
	label         String
	recipientName String   @map("recipient_name")
	phone         String
	line1         String
	line2         String?
	city          String
	region        String
	country       String   @default("CM")
	isDefault     Boolean  @default(false) @map("is_default")
	createdAt     DateTime @default(now()) @map("created_at")
	updatedAt     DateTime @updatedAt @map("updated_at")

	user User @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@index([userId])
	@@map("customer_addresses")
}

enum CustomerOrderStatus {
	PENDING_PAYMENT
	PAID
	PROCESSING
	SHIPPED
	DELIVERED
	CANCELLED
	REFUNDED
}

model CustomerOrder {
	id          String              @id @default(cuid())
	userId      String              @map("user_id")
	orderNumber String              @unique @map("order_number")
	status      CustomerOrderStatus @default(PENDING_PAYMENT)
	totalMinor  Int                 @map("total_minor")
	currency    String              @default("XAF")
	placedAt    DateTime?           @map("placed_at")
	createdAt   DateTime            @default(now()) @map("created_at")
	updatedAt   DateTime            @updatedAt @map("updated_at")

	user User @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@index([userId, placedAt])
	@@map("customer_orders")
}

model Wishlist {
	id                String   @id @default(cuid())
	customerProfileId String   @unique @map("customer_profile_id")
	createdAt         DateTime @default(now()) @map("created_at")
	updatedAt         DateTime @updatedAt @map("updated_at")

	customerProfile CustomerProfile @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
	items           WishlistItem[]

	@@map("wishlists")
}

model WishlistItem {
	id           String   @id @default(cuid())
	wishlistId   String   @map("wishlist_id")
	productId    String?  @map("product_id")
	productSlug  String   @map("product_slug")
	productTitle String   @map("product_title")
	addedAt      DateTime @default(now()) @map("added_at")

	wishlist Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
	product  Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

	@@unique([wishlistId, productSlug])
	@@map("wishlist_items")
}

enum NotificationType {
	ORDER
	ACCOUNT
	PROMOTION
	SUPPORT
	SYSTEM
}

model Notification {
	id        String           @id @default(cuid())
	userId    String           @map("user_id")
	type      NotificationType @default(SYSTEM)
	title     String
	body      String
	readAt    DateTime?        @map("read_at")
	createdAt DateTime         @default(now()) @map("created_at")

	user User @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@index([userId, createdAt])
	@@map("notifications")
}

enum SupportTicketStatus {
	OPEN
	IN_PROGRESS
	RESOLVED
	CLOSED
}

model SupportTicket {
	id        String              @id @default(cuid())
	userId    String              @map("user_id")
	subject   String
	status    SupportTicketStatus @default(OPEN)
	createdAt DateTime            @default(now()) @map("created_at")
	updatedAt DateTime            @updatedAt @map("updated_at")

	user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
	messages SupportMessage[]

	@@index([userId, createdAt])
	@@map("support_tickets")
}

model SupportMessage {
	id           String   @id @default(cuid())
	ticketId     String   @map("ticket_id")
	authorUserId String   @map("author_user_id")
	body         String
	createdAt    DateTime @default(now()) @map("created_at")

	ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

	@@index([ticketId, createdAt])
	@@map("support_messages")
}

enum SellerStatus {
	PENDING
	APPROVED
	REJECTED
	SUSPENDED
}

model SellerProfile {
	id                    String       @id @default(cuid())
	userId                String       @unique @map("user_id")
	shopName              String?      @map("shop_name")
	shopSlug              String?      @unique @map("shop_slug")
	description           String?
	logoPath              String?      @map("logo_path")
	bannerPath            String?      @map("banner_path")
	returnPolicy          String?      @map("return_policy")
	shippingPolicy        String?      @map("shipping_policy")
	shopPhone             String?      @map("shop_phone")
	shopEmail             String?      @map("shop_email")
	addressLine1          String?      @map("address_line1")
	addressLine2          String?      @map("address_line2")
	city                  String?
	region                String?
	country               String?      @default("CM")
	status                SellerStatus @default(PENDING)
	onboardingCompletedAt DateTime?    @map("onboarding_completed_at")
	suspendedAt           DateTime?    @map("suspended_at")
	suspensionReason      String?      @map("suspension_reason")
	createdAt             DateTime     @default(now()) @map("created_at")
	updatedAt             DateTime     @updatedAt @map("updated_at")

	user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
	applications SellerApplication[]
	products     Product[]

	@@map("seller_profiles")
}

enum ApplicationStatus {
	SUBMITTED
	UNDER_REVIEW
	APPROVED
	REJECTED
}

model SellerApplication {
	id              String            @id @default(cuid())
	sellerProfileId String            @map("seller_profile_id")
	businessName    String            @map("business_name")
	description     String?
	contactPhone    String            @map("contact_phone")
	contactEmail    String            @map("contact_email")
	businessCity    String            @map("business_city")
	businessRegion  String            @map("business_region")
	status          ApplicationStatus @default(SUBMITTED)
	submittedAt     DateTime          @default(now()) @map("submitted_at")
	reviewedAt      DateTime?         @map("reviewed_at")
	reviewedById    String?           @map("reviewed_by_id")
	reviewNotes     String?           @map("review_notes")

	sellerProfile SellerProfile @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)

	@@index([status, submittedAt])
	@@map("seller_applications")
}

// --- Catalogue foundation ---

model Category {
	id        String   @id @default(cuid())
	slug      String   @unique
	parentId  String?  @map("parent_id")
	sortOrder Int      @default(0) @map("sort_order")
	isActive  Boolean  @default(true) @map("is_active")
	createdAt DateTime @default(now()) @map("created_at")
	updatedAt DateTime @updatedAt @map("updated_at")

	parent       Category?             @relation("CategoryTree", fields: [parentId], references: [id])
	children     Category[]            @relation("CategoryTree")
	translations CategoryTranslation[]
	products     Product[]

	@@map("categories")
}

model CategoryTranslation {
	id          String  @id @default(cuid())
	categoryId  String  @map("category_id")
	locale      String
	name        String
	description String?

	category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

	@@unique([categoryId, locale])
	@@map("category_translations")
}

enum ProductStatus {
	DRAFT
	PENDING_REVIEW
	ACTIVE
	REJECTED
	OUT_OF_STOCK
	SUSPENDED
	ARCHIVED
}

model Product {
	id              String        @id @default(cuid())
	sellerProfileId String        @map("seller_profile_id")
	categoryId      String        @map("category_id")
	title           String
	slug            String        @unique
	description     String?
	priceMinor      BigInt        @map("price_minor")
	currency        String        @default("XAF")
	stockQty        Int           @default(0) @map("stock_qty")
	status          ProductStatus @default(DRAFT)
	submittedAt     DateTime?     @map("submitted_at")
	reviewedAt      DateTime?     @map("reviewed_at")
	reviewedById    String?       @map("reviewed_by_id")
	reviewNotes     String?       @map("review_notes")
	createdAt       DateTime      @default(now()) @map("created_at")
	updatedAt       DateTime      @updatedAt @map("updated_at")

	sellerProfile        SellerProfile         @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
	category             Category              @relation(fields: [categoryId], references: [id])
	images               ProductImage[]
	inventoryAdjustments InventoryAdjustment[]
	wishlistItems        WishlistItem[]

	@@index([sellerProfileId, status])
	@@index([categoryId, status])
	@@index([status, updatedAt])
	@@map("products")
}

model ProductImage {
	id        String   @id @default(cuid())
	productId String   @map("product_id")
	path      String
	altText   String?  @map("alt_text")
	sortOrder Int      @default(0) @map("sort_order")
	createdAt DateTime @default(now()) @map("created_at")

	product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

	@@index([productId, sortOrder])
	@@map("product_images")
}

model InventoryAdjustment {
	id          String   @id @default(cuid())
	productId   String   @map("product_id")
	actorId     String?  @map("actor_id")
	delta       Int
	previousQty Int      @map("previous_qty")
	newQty      Int      @map("new_qty")
	reason      String
	createdAt   DateTime @default(now()) @map("created_at")

	product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
	actor   User?   @relation("InventoryActor", fields: [actorId], references: [id], onDelete: SetNull)

	@@index([productId, createdAt])
	@@map("inventory_adjustments")
}

// --- Platform ---

model AuditLog {
	id         String   @id @default(cuid())
	action     String
	entityType String?  @map("entity_type")
	entityId   String?  @map("entity_id")
	actorId    String?  @map("actor_id")
	metadata   Json?
	ipAddress  String?  @map("ip_address")
	userAgent  String?  @map("user_agent")
	createdAt  DateTime @default(now()) @map("created_at")

	actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

	@@index([action])
	@@index([entityType, entityId])
	@@index([actorId])
	@@index([createdAt])
	@@map("audit_logs")
}

model SiteSetting {
	id        String   @id @default(cuid())
	key       String   @unique
	value     Json
	updatedAt DateTime @updatedAt @map("updated_at")

	@@map("site_settings")
}

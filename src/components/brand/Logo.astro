---
import type { SupportedLocale } from '@/config/site';
import { localizedPath } from '@/i18n';

interface Props {
	locale: SupportedLocale;
	class?: string;
	showWordmark?: boolean;
}

const { locale, class: className, showWordmark = true } = Astro.props;
const homeHref = localizedPath(locale);
---

<a
	href={homeHref}
	class:list={[
		'inline-flex items-center gap-2 rounded-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600',
		className,
	]}
	aria-label="Trimnexa"
>
	<img src="/brand/logo-mark.svg" alt="" width="40" height="40" class="h-10 w-10 shrink-0" />
	{
		showWordmark && (
			<span class="text-xl font-bold tracking-tight text-primary-800">
				Trim<span class="text-accent-600">nexa</span>
			</span>
		)
	}
</a>

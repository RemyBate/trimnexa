---
import Alert from '@/components/common/Alert.astro';
import Button from '@/components/common/Button.astro';
import Card from '@/components/common/Card.astro';
import type { AdminProductDetail } from '@/lib/admin/products';
import type { SupportedLocale } from '@/config/site';
import { localizedPath } from '@/i18n';

interface Labels {
	overview: string;
	description: string;
	seller: string;
	category: string;
	price: string;
	stock: string;
	status: string;
	reviewNotes: string;
	reviewNotesRequired: string;
	approve: string;
	approving: string;
	reject: string;
	rejecting: string;
	rejectConfirm: string;
	suspend: string;
	suspensionReason: string;
	successApproved: string;
	successRejected: string;
	errorGeneric: string;
	errorNotFound: string;
	errorAlreadyReviewed: string;
	errorUnauthorized: string;
	errorRejectionReasonRequired: string;
	images: string;
}

interface Props {
	locale: SupportedLocale;
	product: AdminProductDetail;
	labels: Labels;
}

const { locale, product, labels } = Astro.props;
const canReview = product.status === 'PENDING_REVIEW';
const canSuspend = product.status === 'ACTIVE' || product.status === 'OUT_OF_STOCK';

const config = JSON.stringify({
	productId: product.id,
	redirectUrlApproved: localizedPath(locale, '/admin/products?flash=approved'),
	redirectUrlRejected: localizedPath(locale, '/admin/products?flash=rejected'),
	labels,
});
---

<div id="product-review-success" class="mb-4 hidden" role="status" tabindex="-1">
	<Alert variant="success">
		<span id="product-review-success-text">{labels.successApproved}</span>
	</Alert>
</div>

<div id="product-review-error" class="mb-4 hidden" role="alert" tabindex="-1">
	<Alert variant="error">
		<span id="product-review-error-text">{labels.errorGeneric}</span>
	</Alert>
</div>

<div class="space-y-6" data-review-config={config}>
	<Card class="p-6">
		<h2 class="text-lg font-semibold text-neutral-900">{labels.overview}</h2>
		<dl class="mt-4 grid gap-3 text-sm sm:grid-cols-2">
			<div>
				<dt class="text-neutral-500">{labels.status}</dt>
				<dd class="font-medium text-neutral-900">{product.status}</dd>
			</div>
			<div>
				<dt class="text-neutral-500">{labels.seller}</dt>
				<dd class="font-medium text-neutral-900">
					{product.sellerShopName ?? product.sellerEmail}
				</dd>
			</div>
			<div>
				<dt class="text-neutral-500">{labels.category}</dt>
				<dd class="font-medium text-neutral-900">{product.categoryName}</dd>
			</div>
			<div>
				<dt class="text-neutral-500">{labels.price}</dt>
				<dd class="font-medium text-neutral-900">{product.priceFormatted}</dd>
			</div>
			<div>
				<dt class="text-neutral-500">{labels.stock}</dt>
				<dd class="font-medium text-neutral-900">{product.stockQty}</dd>
			</div>
		</dl>
	</Card>

	{
		product.description ? (
			<Card class="p-6">
				<h2 class="text-lg font-semibold text-neutral-900">{labels.description}</h2>
				<p class="mt-3 text-sm text-neutral-800">{product.description}</p>
			</Card>
		) : null
	}

	{
		product.images.length > 0 ? (
			<Card class="p-6">
				<h2 class="text-lg font-semibold text-neutral-900">{labels.images}</h2>
				<div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
					{product.images.map((image) => (
						<img
							src={image.url}
							alt={image.altText ?? product.title}
							class="h-28 w-full rounded-md border border-neutral-200 object-cover"
						/>
					))}
				</div>
			</Card>
		) : null
	}

	<Card class="p-6">
		<label for="product-review-notes" class="mb-1 block text-sm font-medium text-neutral-800">
			{labels.reviewNotes}
		</label>
		<textarea
			id="product-review-notes"
			rows="3"
			class="block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200"
		>
			{product.reviewNotes ?? ''}
		</textarea>
		<p id="product-review-notes-help" class="mt-1 hidden text-sm text-error-700">
			{labels.reviewNotesRequired}
		</p>

		{
			canReview ? (
				<div class="mt-4 flex flex-wrap gap-3">
					<Button type="button" data-action="approve" id="product-action-approve">
						<span id="product-action-approve-label">{labels.approve}</span>
					</Button>
					<Button type="button" data-action="reject" variant="secondary" id="product-action-reject">
						<span id="product-action-reject-label">{labels.reject}</span>
					</Button>
				</div>
			) : canSuspend ? (
				<div class="mt-4 space-y-3">
					<label for="product-suspension-reason" class="block text-sm font-medium text-neutral-800">
						{labels.suspensionReason}
					</label>
					<input
						id="product-suspension-reason"
						type="text"
						class="block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200"
					/>
					<Button type="button" data-action="suspend" variant="secondary" id="product-action-suspend">
						{labels.suspend}
					</Button>
				</div>
			) : null
		}
	</Card>
</div>

<script>
	const root = document.querySelector('[data-review-config]') as HTMLElement | null;
	if (!root) {
		throw new Error('Product review panel config not found');
	}

	const config = JSON.parse(root.dataset.reviewConfig ?? '{}') as {
		productId: string;
		redirectUrlApproved: string;
		redirectUrlRejected: string;
		labels: Record<string, string>;
	};

	const successBox = document.getElementById('product-review-success');
	const successText = document.getElementById('product-review-success-text');
	const errorBox = document.getElementById('product-review-error');
	const errorText = document.getElementById('product-review-error-text');
	const reviewNotes = document.getElementById('product-review-notes') as HTMLTextAreaElement;
	const reviewNotesHelp = document.getElementById('product-review-notes-help');
	const actionButtons = root.querySelectorAll<HTMLButtonElement>('[data-action]');

	const errorMessages: Record<string, string> = {
		not_found: config.labels.errorNotFound,
		already_reviewed: config.labels.errorAlreadyReviewed,
		unauthorized: config.labels.errorUnauthorized,
		forbidden: config.labels.errorUnauthorized,
		rejection_reason_required: config.labels.errorRejectionReasonRequired,
	};

	function setBusy(isBusy: boolean) {
		for (const button of actionButtons) {
			button.disabled = isBusy;
		}
	}

	function showError(message: string) {
		successBox?.classList.add('hidden');
		if (errorText) {
			errorText.textContent = message;
		}
		errorBox?.classList.remove('hidden');
	}

	function showSuccess(message: string) {
		errorBox?.classList.add('hidden');
		reviewNotesHelp?.classList.add('hidden');
		if (successText) {
			successText.textContent = message;
		}
		successBox?.classList.remove('hidden');
	}

	async function postAction(action: string, body?: Record<string, string>) {
		successBox?.classList.add('hidden');
		errorBox?.classList.add('hidden');
		reviewNotesHelp?.classList.add('hidden');
		setBusy(true);

		const approveLabel = document.getElementById('product-action-approve-label');
		const rejectLabel = document.getElementById('product-action-reject-label');
		const previousApprove = approveLabel?.textContent;
		const previousReject = rejectLabel?.textContent;

		if (action === 'approve' && approveLabel) {
			approveLabel.textContent = config.labels.approving;
		}
		if (action === 'reject' && rejectLabel) {
			rejectLabel.textContent = config.labels.rejecting;
		}

		try {
			const response = await fetch(`/api/admin/products/${config.productId}/${action}`, {
				method: 'POST',
				headers: body ? { 'Content-Type': 'application/json' } : undefined,
				body: body ? JSON.stringify(body) : undefined,
				credentials: 'same-origin',
			});

			const payload = (await response.json()) as { error?: string };
			if (!response.ok) {
				showError(errorMessages[payload.error ?? ''] ?? config.labels.errorGeneric);
				return;
			}

			const successMessage =
				action === 'approve' ? config.labels.successApproved : config.labels.successRejected;
			const redirectUrl =
				action === 'approve' ? config.redirectUrlApproved : config.redirectUrlRejected;
			showSuccess(successMessage);
			window.setTimeout(() => {
				window.location.href = redirectUrl;
			}, 1200);
		} catch {
			showError(config.labels.errorGeneric);
		} finally {
			setBusy(false);
			if (approveLabel && previousApprove) {
				approveLabel.textContent = previousApprove;
			}
			if (rejectLabel && previousReject) {
				rejectLabel.textContent = previousReject;
			}
		}
	}

	for (const button of actionButtons) {
		button.addEventListener('click', () => {
			const action = button.dataset.action;
			if (!action) {
				return;
			}

			if (action === 'approve') {
				void postAction('approve', { reviewNotes: reviewNotes.value });
				return;
			}

			if (action === 'reject') {
				const reason = reviewNotes.value.trim();
				if (reason.length < 3) {
					reviewNotesHelp?.classList.remove('hidden');
					reviewNotes.focus();
					showError(config.labels.errorRejectionReasonRequired);
					return;
				}

				if (!window.confirm(config.labels.rejectConfirm)) {
					return;
				}

				void postAction('reject', { reviewNotes: reason });
				return;
			}

			if (action === 'suspend') {
				const reasonInput = document.getElementById(
					'product-suspension-reason',
				) as HTMLInputElement;
				void postAction('suspend', { reason: reasonInput.value });
			}
		});
	}
</script>

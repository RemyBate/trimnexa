---
import Logo from '@/components/brand/Logo.astro';
import LanguageSwitcher from '@/components/layout/LanguageSwitcher.astro';
import SearchBar from '@/components/layout/SearchBar.astro';
import UserMenu from '@/components/layout/UserMenu.astro';
import { mainNavLinks, resolveNavHref } from '@/config/navigation';
import type { SupportedLocale } from '@/config/site';
import type { PageContext } from '@/i18n';
import { localizedPath } from '@/i18n';

interface SessionUser {
	email: string;
	name?: string | null;
	firstName?: string | null;
}

interface SellerMenuState {
	showSellerDashboard: boolean;
	showSellerApplication: boolean;
	showBecomeSeller: boolean;
}

interface Props {
	locale: SupportedLocale;
	currentPath: string;
	t: PageContext['t'];
	user: SessionUser | null;
	sellerMenuState?: SellerMenuState | null;
}

const { locale, currentPath, t, user, sellerMenuState } = Astro.props;
const toggleId = 'mobile-nav-toggle';

const userMenuLabels = {
	openMenu: t('userMenu.openMenu'),
	myAccount: t('userMenu.myAccount'),
	orders: t('userMenu.orders'),
	wishlist: t('userMenu.wishlist'),
	addresses: t('userMenu.addresses'),
	settings: t('userMenu.settings'),
	becomeSeller: t('userMenu.becomeSeller'),
	sellerDashboard: t('userMenu.sellerDashboard'),
	sellerApplication: t('userMenu.sellerApplication'),
	signOut: t('userMenu.signOut'),
};
---

<header class="sticky top-0 z-40 border-b border-neutral-200 bg-white shadow-sm">
	<input type="checkbox" id={toggleId} class="peer sr-only" />

	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="flex h-16 items-center gap-4 lg:h-[4.5rem]">
			<div class="flex shrink-0 items-center gap-3">
				<label
					for={toggleId}
					class="inline-flex h-11 w-11 cursor-pointer items-center justify-center rounded-md text-neutral-700 hover:bg-neutral-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600 lg:hidden"
				>
					<span class="sr-only">{t('common.menu')}</span>
					<svg
						class="h-6 w-6"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						aria-hidden="true"
					>
						<path stroke-linecap="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path>
					</svg>
				</label>
				<Logo locale={locale} class="min-w-0" />
			</div>

			<div class="hidden flex-1 lg:block">
				<SearchBar locale={locale} t={t} />
			</div>

			<nav class="ml-auto hidden items-center gap-2 lg:flex" aria-label="Account">
				<LanguageSwitcher locale={locale} currentPath={currentPath} t={t} />
				{
					user ? (
						<UserMenu
							locale={locale}
							user={user}
							labels={userMenuLabels}
							sellerMenuState={sellerMenuState}
						/>
					) : (
						<>
							<a
								href={localizedPath(locale, '/auth/login')}
								class="rounded-md px-3 py-2 text-sm font-medium text-neutral-700 hover:bg-neutral-100 hover:text-primary-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
							>
								{t('common.signIn')}
							</a>
							<a
								href={localizedPath(locale, '/auth/register')}
								class="rounded-md bg-primary-700 px-3 py-2 text-sm font-medium text-white hover:bg-primary-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
							>
								{t('common.createAccount')}
							</a>
						</>
					)
				}
				<a
					href={localizedPath(locale, '/cart')}
					class="inline-flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium text-neutral-700 hover:bg-neutral-100 hover:text-primary-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
					aria-label={t('common.cart')}
				>
					<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
						<path
							d="M3 3h1.5l1.2 6.3a2 2 0 001.95 1.62h7.28a2 2 0 001.95-1.62L17.5 6H6.12M8 17a1 1 0 100-2 1 1 0 000 2zm7-1a1 1 0 11-2 0 1 1 0 012 0z"
						></path>
					</svg>
					<span class="hidden xl:inline">{t('common.cart')}</span>
				</a>
			</nav>
		</div>

		<div class="pb-3 lg:hidden">
			<SearchBar locale={locale} t={t} />
		</div>
	</div>

	<nav
		class="hidden border-t border-neutral-200 bg-white peer-checked:block lg:hidden"
		aria-label="Main"
	>
		<div class="mx-auto max-w-7xl space-y-1 px-4 py-3 sm:px-6">
			{
				mainNavLinks.map((link) => (
					<a
						href={resolveNavHref(locale, link.href)}
						class="block rounded-md px-3 py-2 text-sm font-medium text-neutral-700 hover:bg-primary-50 hover:text-primary-800"
					>
						{t(link.key)}
					</a>
				))
			}
			<div class="border-t border-neutral-200 pt-3">
				<LanguageSwitcher locale={locale} currentPath={currentPath} t={t} />
			</div>
			<div class="border-t border-neutral-200 pt-3">
				{
					user ? (
						<div class="space-y-1">
							<p class="px-3 py-1 text-xs font-medium uppercase tracking-wide text-neutral-500">
								{t('common.account')}
							</p>
							<a
								href={localizedPath(locale, '/account')}
								class="block rounded-md px-3 py-2 text-sm font-medium text-neutral-700 hover:bg-primary-50 hover:text-primary-800"
							>
								{t('userMenu.myAccount')}
							</a>
							<a
								href={localizedPath(locale, '/auth/logout')}
								class="block rounded-md px-3 py-2 text-sm font-medium text-neutral-700 hover:bg-primary-50 hover:text-primary-800"
							>
								{t('userMenu.signOut')}
							</a>
						</div>
					) : (
						<div class="space-y-1">
							<a
								href={localizedPath(locale, '/auth/login')}
								class="block rounded-md px-3 py-2 text-sm font-medium text-neutral-700 hover:bg-primary-50 hover:text-primary-800"
							>
								{t('common.signIn')}
							</a>
							<a
								href={localizedPath(locale, '/auth/register')}
								class="block rounded-md bg-primary-700 px-3 py-2 text-sm font-medium text-white hover:bg-primary-800"
							>
								{t('common.createAccount')}
							</a>
						</div>
					)
				}
			</div>
		</div>
	</nav>
</header>

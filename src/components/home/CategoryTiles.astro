---
import Card from '@/components/common/Card.astro';
import Container from '@/components/common/Container.astro';
import { categoryLinks } from '@/config/navigation';
import type { SupportedLocale } from '@/config/site';
import type { PageContext } from '@/i18n';

interface Props {
	locale: SupportedLocale;
	t: PageContext['t'];
}

const { t } = Astro.props;

const categoryColors = [
	'from-primary-600 to-primary-800',
	'from-accent-500 to-accent-600',
	'from-info-600 to-primary-700',
	'from-success-600 to-primary-700',
	'from-warning-600 to-accent-600',
	'from-neutral-600 to-primary-800',
];
---

<section id="categories" class="bg-white py-12 sm:py-16">
	<Container>
		<div class="mx-auto max-w-2xl text-center">
			<h2 class="text-3xl font-bold text-neutral-900">{t('home.featuredCategories')}</h2>
			<p class="mt-3 text-neutral-600">{t('home.featuredCategoriesSubtitle')}</p>
		</div>
		<ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{
				categoryLinks.map((category, index) => (
					<li>
						<Card class="overflow-hidden p-0">
							<div
								class:list={[
									'flex h-28 items-end bg-gradient-to-br p-4 text-white',
									categoryColors[index % categoryColors.length],
								]}
							>
								<span class="text-lg font-semibold">{t(category.key)}</span>
							</div>
						</Card>
					</li>
				))
			}
		</ul>
	</Container>
</section>

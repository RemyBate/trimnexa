---
import Button from '@/components/common/Button.astro';
import type { SupportedLocale } from '@/config/site';
import { localizedPath } from '@/i18n';

interface Labels {
	addToCart: string;
	buyNow: string;
	addToWishlist: string;
	inWishlist: string;
	outOfStock: string;
	adding: string;
	added: string;
	errorGeneric: string;
	errorStock: string;
	errorUnavailable: string;
	signInForWishlist: string;
}

interface Props {
	locale: SupportedLocale;
	productId: string;
	inStock: boolean;
	isAuthenticated: boolean;
	inWishlist: boolean;
	labels: Labels;
}

const { locale, productId, inStock, isAuthenticated, inWishlist, labels } = Astro.props;
const config = JSON.stringify({
	locale,
	productId,
	cartPath: localizedPath(locale, '/cart'),
	loginPath: `${localizedPath(locale, '/auth/login')}?returnTo=${encodeURIComponent(localizedPath(locale, `/products`))}`,
	labels,
});
---

<div data-product-purchase data-config={config} class="space-y-3">
	{
		inStock ? (
			<div class="flex flex-col gap-3 sm:flex-row">
				<Button type="button" data-action="add-to-cart">
					{labels.addToCart}
				</Button>
				<Button type="button" variant="secondary" data-action="buy-now">
					{labels.buyNow}
				</Button>
			</div>
		) : (
			<Button type="button" disabled>
				{labels.outOfStock}
			</Button>
		)
	}

	{
		isAuthenticated ? (
			<button
				type="button"
				data-action="wishlist"
				data-in-wishlist={inWishlist ? '1' : '0'}
				class="text-sm font-medium text-primary-700 hover:text-primary-800"
			>
				{inWishlist ? labels.inWishlist : labels.addToWishlist}
			</button>
		) : (
			<a
				href={`${localizedPath(locale, '/auth/login')}?returnTo=${encodeURIComponent(Astro.url.pathname)}`}
				class="inline-block text-sm font-medium text-primary-700 hover:text-primary-800"
			>
				{labels.signInForWishlist}
			</a>
		)
	}

	<p class="hidden text-sm text-success-700" data-purchase-success role="status"></p>
	<p class="hidden text-sm text-error-700" data-purchase-error role="alert"></p>
</div>

<script>
	function initProductPurchase() {
		const root = document.querySelector('[data-product-purchase]');
		if (!(root instanceof HTMLElement) || root.dataset.bound === '1') return;
		root.dataset.bound = '1';

		const config = JSON.parse(root.dataset.config || '{}') as {
			locale: string;
			productId: string;
			cartPath: string;
			labels: {
				adding: string;
				added: string;
				errorGeneric: string;
				errorStock: string;
				errorUnavailable: string;
				addToWishlist: string;
				inWishlist: string;
			};
		};

		const successEl = root.querySelector('[data-purchase-success]');
		const errorEl = root.querySelector('[data-purchase-error]');

		function setMessage(kind: 'success' | 'error', message: string) {
			if (successEl instanceof HTMLElement) {
				successEl.classList.toggle('hidden', kind !== 'success');
				successEl.textContent = kind === 'success' ? message : '';
			}
			if (errorEl instanceof HTMLElement) {
				errorEl.classList.toggle('hidden', kind !== 'error');
				errorEl.textContent = kind === 'error' ? message : '';
			}
		}

		async function post(url: string, body: unknown) {
			const response = await fetch(url, {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'x-trimnexa-locale': config.locale,
				},
				body: JSON.stringify(body),
			});
			const payload = (await response.json().catch(() => ({}))) as { error?: string };
			return { ok: response.ok, status: response.status, payload };
		}

		root.querySelector('[data-action="add-to-cart"]')?.addEventListener('click', async (event) => {
			const button = event.currentTarget;
			if (!(button instanceof HTMLButtonElement)) return;
			button.disabled = true;
			setMessage('success', config.labels.adding);
			const result = await post('/api/cart/items', {
				productId: config.productId,
				quantity: 1,
			});
			button.disabled = false;
			if (!result.ok) {
				const message =
					result.payload.error === 'insufficient_stock' || result.payload.error === 'out_of_stock'
						? config.labels.errorStock
						: result.payload.error === 'product_unavailable'
							? config.labels.errorUnavailable
							: config.labels.errorGeneric;
				setMessage('error', message);
				return;
			}
			setMessage('success', config.labels.added);
		});

		root.querySelector('[data-action="buy-now"]')?.addEventListener('click', async (event) => {
			const button = event.currentTarget;
			if (!(button instanceof HTMLButtonElement)) return;
			button.disabled = true;
			const result = await post('/api/cart/buy-now', { productId: config.productId });
			if (!result.ok) {
				button.disabled = false;
				const message =
					result.payload.error === 'insufficient_stock' ||
					result.payload.error === 'product_unavailable'
						? config.labels.errorStock
						: config.labels.errorGeneric;
				setMessage('error', message);
				return;
			}
			window.location.href = config.cartPath;
		});

		root.querySelector('[data-action="wishlist"]')?.addEventListener('click', async (event) => {
			const button = event.currentTarget;
			if (!(button instanceof HTMLButtonElement)) return;
			const inWishlist = button.dataset.inWishlist === '1';
			button.disabled = true;

			if (inWishlist) {
				button.disabled = false;
				return;
			}

			const result = await post('/api/account/wishlist/items', {
				productId: config.productId,
			});
			button.disabled = false;

			if (!result.ok) {
				setMessage('error', config.labels.errorGeneric);
				return;
			}

			button.dataset.inWishlist = '1';
			button.textContent = config.labels.inWishlist;
			setMessage('success', config.labels.inWishlist);
		});
	}

	document.addEventListener('DOMContentLoaded', initProductPurchase);
	initProductPurchase();
</script>

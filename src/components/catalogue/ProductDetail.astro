---
import Breadcrumbs from '@/components/catalogue/Breadcrumbs.astro';
import Card from '@/components/common/Card.astro';
import ProductPurchaseActions from '@/components/catalogue/ProductPurchaseActions.astro';
import type { SupportedLocale } from '@/config/site';
import { localizedPath } from '@/i18n';
import type { CatalogueProductDetail } from '@/lib/catalogue/types';

interface Labels {
	outOfStock: string;
	inStock: string;
	bySeller: string;
	category: string;
	description: string;
	home: string;
	products: string;
	addToCart: string;
	buyNow: string;
	addToWishlist: string;
	inWishlist: string;
	adding: string;
	added: string;
	errorGeneric: string;
	errorStock: string;
	errorUnavailable: string;
	signInForWishlist: string;
}

interface Props {
	locale: SupportedLocale;
	product: CatalogueProductDetail;
	labels: Labels;
	isAuthenticated: boolean;
	inWishlist: boolean;
}

const { locale, product, labels, isAuthenticated, inWishlist } = Astro.props;
const shopHref = product.sellerShopSlug
	? localizedPath(locale, `/shops/${product.sellerShopSlug}`)
	: null;
const categoryHref = localizedPath(locale, `/categories/${product.categorySlug}`);
---

<div class="space-y-6">
	<Breadcrumbs
		locale={locale}
		items={[
			{ label: labels.home, href: localizedPath(locale, '/') },
			{ label: labels.products, href: localizedPath(locale, '/products') },
			{ label: product.categoryName, href: categoryHref },
			{ label: product.title },
		]}
	/>

	<div class="grid gap-8 lg:grid-cols-2">
		<div class="space-y-3">
			{
				product.images.length > 0 ? (
					<div class="overflow-hidden rounded-lg border border-neutral-200 bg-white">
						<img
							src={product.images[0]?.url}
							alt={product.images[0]?.altText ?? product.title}
							class="aspect-square w-full object-cover"
						/>
					</div>
				) : (
					<div class="flex aspect-square items-center justify-center rounded-lg border border-neutral-200 bg-neutral-100 text-neutral-500">
						{product.title}
					</div>
				)
			}
			{
				product.images.length > 1 ? (
					<div class="grid grid-cols-4 gap-2">
						{product.images.slice(1).map((image) => (
							<img
								src={image.url}
								alt={image.altText ?? product.title}
								class="aspect-square rounded-md border border-neutral-200 object-cover"
								loading="lazy"
							/>
						))}
					</div>
				) : null
			}
		</div>

		<div class="space-y-4">
			<div>
				<h1 class="text-3xl font-bold text-neutral-900">{product.title}</h1>
				<p class="mt-2 text-2xl font-bold text-neutral-900">{product.priceFormatted}</p>
			</div>

			<div class="flex flex-wrap gap-2 text-sm">
				<span
					class:list={[
						'rounded-full px-3 py-1 font-medium',
						product.inStock ? 'bg-success-50 text-success-800' : 'bg-neutral-100 text-neutral-700',
					]}
				>
					{product.inStock ? `${labels.inStock}: ${product.stockQty}` : labels.outOfStock}
				</span>
			</div>

			<dl class="grid gap-3 text-sm">
				<div>
					<dt class="text-neutral-500">{labels.category}</dt>
					<dd>
						<a href={categoryHref} class="font-medium text-primary-700 hover:text-primary-800">
							{product.categoryName}
						</a>
					</dd>
				</div>
				{
					product.sellerShopName && shopHref ? (
						<div>
							<dt class="text-neutral-500">{labels.bySeller}</dt>
							<dd>
								<a href={shopHref} class="font-medium text-primary-700 hover:text-primary-800">
									{product.sellerShopName}
								</a>
							</dd>
						</div>
					) : null
				}
			</dl>

			<ProductPurchaseActions
				locale={locale}
				productId={product.id}
				inStock={product.inStock && product.stockQty > 0}
				isAuthenticated={isAuthenticated}
				inWishlist={inWishlist}
				labels={{
					addToCart: labels.addToCart,
					buyNow: labels.buyNow,
					addToWishlist: labels.addToWishlist,
					inWishlist: labels.inWishlist,
					outOfStock: labels.outOfStock,
					adding: labels.adding,
					added: labels.added,
					errorGeneric: labels.errorGeneric,
					errorStock: labels.errorStock,
					errorUnavailable: labels.errorUnavailable,
					signInForWishlist: labels.signInForWishlist,
				}}
			/>

			{
				product.description ? (
					<Card class="p-5">
						<h2 class="text-lg font-semibold text-neutral-900">{labels.description}</h2>
						<p class="mt-3 whitespace-pre-wrap text-sm leading-relaxed text-neutral-700">
							{product.description}
						</p>
					</Card>
				) : null
			}
		</div>
	</div>
</div>

---
import Alert from '@/components/common/Alert.astro';
import Button from '@/components/common/Button.astro';
import { PASSWORD_MIN_LENGTH } from '@/lib/auth/validation';

interface Labels {
	password: string;
	confirmPassword: string;
	passwordHint: string;
	showPassword: string;
	hidePassword: string;
	submit: string;
	submitting: string;
	success: string;
	errorGeneric: string;
	errorInvalidToken: string;
	errorRateLimited: string;
	errorMismatch: string;
	errorMissingToken: string;
	errorPasswordRequired: string;
	errorPasswordTooShort: string;
	errorConfirmRequired: string;
}

interface Props {
	loginPath: string;
	invalidToken?: boolean;
	labels: Labels;
}

const { loginPath, invalidToken = false, labels } = Astro.props;
const formConfig = JSON.stringify({ loginPath, labels });
---

<div class="space-y-4">
	{
		invalidToken ? (
			<div role="alert">
				<Alert variant="error">{labels.errorInvalidToken}</Alert>
			</div>
		) : null
	}

	<div id="reset-form-success" class="hidden" role="status">
		<Alert variant="success">
			<span id="reset-form-success-text"></span>
		</Alert>
	</div>

	<div id="reset-form-error" class="hidden" role="alert">
		<Alert variant="error">
			<span id="reset-form-error-text"></span>
		</Alert>
	</div>

	<form id="reset-form" class="space-y-4" data-config={formConfig} novalidate>
		<div class="auth-field">
			<label for="reset-password" class="mb-1 block text-sm font-medium text-neutral-800">
				{labels.password}
				<span class="text-error-700" aria-hidden="true"> *</span>
			</label>
			<p class="mb-1 text-xs text-neutral-600">{labels.passwordHint}</p>
			<input
				id="reset-password"
				name="password"
				type="password"
				required
				minlength={PASSWORD_MIN_LENGTH}
				autocomplete="new-password"
				aria-describedby="reset-password-error"
				class="auth-input block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200"
			/>
			<p id="reset-password-error" class="mt-1 hidden text-sm text-error-700" role="alert"></p>
		</div>
		<div class="auth-field">
			<label for="reset-confirm-password" class="mb-1 block text-sm font-medium text-neutral-800">
				{labels.confirmPassword}
				<span class="text-error-700" aria-hidden="true"> *</span>
			</label>
			<input
				id="reset-confirm-password"
				name="confirmPassword"
				type="password"
				required
				minlength={PASSWORD_MIN_LENGTH}
				autocomplete="off"
				aria-describedby="reset-confirm-password-error"
				class="auth-input block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200"
			/>
			<p id="reset-confirm-password-error" class="mt-1 hidden text-sm text-error-700" role="alert">
			</p>
		</div>
		<Button type="submit" class="w-full" id="reset-submit">
			<span id="reset-submit-label">{labels.submit}</span>
		</Button>
	</form>
</div>

<script>
	import { authClient } from '@/lib/auth-client';
	import { mapAuthError } from '@/lib/auth/errors';
	import {
		hasValidationErrors,
		readRegisterFormValues,
		validatePasswordFields,
	} from '@/lib/auth/validation';

	interface ResetFormConfig {
		loginPath: string;
		labels: {
			submit: string;
			submitting: string;
			success: string;
			errorGeneric: string;
			errorInvalidToken: string;
			errorRateLimited: string;
			errorMismatch: string;
			errorMissingToken: string;
			errorPasswordRequired: string;
			errorPasswordTooShort: string;
			errorConfirmRequired: string;
		};
	}

	const form = document.getElementById('reset-form') as HTMLFormElement | null;
	if (!form) {
		throw new Error('Reset password form not found');
	}

	const config = JSON.parse(form.dataset.config ?? '{}') as ResetFormConfig;
	const submitButton = document.getElementById('reset-submit') as HTMLButtonElement | null;
	const submitLabel = document.getElementById('reset-submit-label');

	form.addEventListener('submit', async (event) => {
		event.preventDefault();

		const token = new URLSearchParams(window.location.search).get('token');
		const errorBox = document.getElementById('reset-form-error');
		const errorText = document.getElementById('reset-form-error-text');
		const successBox = document.getElementById('reset-form-success');
		const successText = document.getElementById('reset-form-success-text');

		errorBox?.classList.add('hidden');
		successBox?.classList.add('hidden');

		if (!token) {
			if (errorText) {
				errorText.textContent = config.labels.errorMissingToken;
			}

			errorBox?.classList.remove('hidden');
			return;
		}

		const { password, confirmPassword } = readRegisterFormValues(form);
		const validationErrors = validatePasswordFields(password, confirmPassword);

		if (validationErrors.password === 'required') {
			const errorElement = document.getElementById('reset-password-error');
			errorElement?.classList.remove('hidden');
			if (errorElement) {
				errorElement.textContent = config.labels.errorPasswordRequired;
			}

			return;
		}

		if (validationErrors.password === 'password_too_short') {
			const errorElement = document.getElementById('reset-password-error');
			errorElement?.classList.remove('hidden');
			if (errorElement) {
				errorElement.textContent = config.labels.errorPasswordTooShort;
			}

			return;
		}

		if (validationErrors.confirmPassword === 'password_mismatch') {
			const errorElement = document.getElementById('reset-confirm-password-error');
			errorElement?.classList.remove('hidden');
			if (errorElement) {
				errorElement.textContent = config.labels.errorMismatch;
			}

			return;
		}

		if (hasValidationErrors(validationErrors) && validationErrors.confirmPassword === 'required') {
			const errorElement = document.getElementById('reset-confirm-password-error');
			errorElement?.classList.remove('hidden');
			if (errorElement) {
				errorElement.textContent = config.labels.errorConfirmRequired;
			}

			return;
		}

		if (submitButton) {
			submitButton.disabled = true;
		}

		if (submitLabel) {
			submitLabel.textContent = config.labels.submitting;
		}

		try {
			const result = await authClient.resetPassword({ newPassword: password, token });

			if (result.error) {
				const message = mapAuthError('reset_password', result.error, {
					generic: config.labels.errorGeneric,
					suspended: config.labels.errorGeneric,
					invalidCredentials: config.labels.errorGeneric,
					duplicateEmail: config.labels.errorGeneric,
					invalidResetToken: config.labels.errorInvalidToken,
					rateLimited: config.labels.errorRateLimited,
				});

				if (errorText) {
					errorText.textContent = message;
				}

				errorBox?.classList.remove('hidden');
				return;
			}

			if (successText) {
				successText.textContent = config.labels.success;
			}

			successBox?.classList.remove('hidden');

			const loginUrl = new URL(config.loginPath, window.location.origin);
			loginUrl.searchParams.set('reset', 'success');
			window.setTimeout(() => {
				window.location.href = `${loginUrl.pathname}${loginUrl.search}`;
			}, 1200);
		} catch {
			if (errorText) {
				errorText.textContent = config.labels.errorGeneric;
			}

			errorBox?.classList.remove('hidden');
		} finally {
			if (submitButton) {
				submitButton.disabled = false;
			}

			if (submitLabel) {
				submitLabel.textContent = config.labels.submit;
			}
		}
	});
</script>

---
import Alert from '@/components/common/Alert.astro';
import Button from '@/components/common/Button.astro';
import AuthFormField from '@/components/auth/AuthFormField.astro';

interface Labels {
	email: string;
	submit: string;
	submitting: string;
	success: string;
	errorGeneric: string;
	errorRateLimited: string;
	errorEmailRequired: string;
	errorEmailInvalid: string;
}

interface Props {
	locale: string;
	labels: Labels;
}

const { locale, labels } = Astro.props;
const formConfig = JSON.stringify({ locale, labels });
---

<div id="forgot-form-success" class="mb-4 hidden" role="status">
	<Alert variant="success">
		<span id="forgot-form-success-text"></span>
	</Alert>
</div>

<div id="forgot-form-error" class="mb-4 hidden" role="alert">
	<Alert variant="error">
		<span id="forgot-form-error-text"></span>
	</Alert>
</div>

<form id="forgot-form" class="space-y-4" data-config={formConfig} novalidate>
	<AuthFormField
		id="forgot-email"
		name="email"
		type="email"
		label={labels.email}
		required
		autocomplete="email"
		errorId="forgot-email-error"
	/>
	<Button type="submit" class="w-full" id="forgot-submit">
		<span id="forgot-submit-label">{labels.submit}</span>
	</Button>
</form>

<script>
	import { authClient } from '@/lib/auth-client';
	import { mapAuthError } from '@/lib/auth/errors';
	import { hasValidationErrors, isValidEmail, validateLoginForm } from '@/lib/auth/validation';

	interface ForgotFormConfig {
		locale: string;
		labels: {
			email: string;
			submit: string;
			submitting: string;
			success: string;
			errorGeneric: string;
			errorRateLimited: string;
			errorEmailRequired: string;
			errorEmailInvalid: string;
		};
	}

	const form = document.getElementById('forgot-form') as HTMLFormElement | null;
	if (!form) {
		throw new Error('Forgot password form not found');
	}

	const config = JSON.parse(form.dataset.config ?? '{}') as ForgotFormConfig;
	const successBox = document.getElementById('forgot-form-success');
	const successText = document.getElementById('forgot-form-success-text');
	const errorBox = document.getElementById('forgot-form-error');
	const errorText = document.getElementById('forgot-form-error-text');
	const submitButton = document.getElementById('forgot-submit') as HTMLButtonElement | null;
	const submitLabel = document.getElementById('forgot-submit-label');

	function setFieldError(message: string | null) {
		const input = document.getElementById('forgot-email') as HTMLInputElement | null;
		const errorElement = document.getElementById('forgot-email-error');

		if (!input || !errorElement) {
			return;
		}

		if (message) {
			errorElement.textContent = message;
			errorElement.classList.remove('hidden');
			input.setAttribute('aria-invalid', 'true');
			return;
		}

		errorElement.textContent = '';
		errorElement.classList.add('hidden');
		input.setAttribute('aria-invalid', 'false');
	}

	form.addEventListener('submit', async (event) => {
		event.preventDefault();
		errorBox?.classList.add('hidden');
		successBox?.classList.add('hidden');
		setFieldError(null);

		const email = String(new FormData(form).get('email') ?? '');
		const validationErrors = validateLoginForm({ email, password: 'placeholder' });

		if (!email.trim()) {
			setFieldError(config.labels.errorEmailRequired);
			return;
		}

		if (!isValidEmail(email)) {
			setFieldError(config.labels.errorEmailInvalid);
			return;
		}

		if (hasValidationErrors(validationErrors) && validationErrors.email) {
			setFieldError(config.labels.errorEmailInvalid);
			return;
		}

		if (submitButton) {
			submitButton.disabled = true;
		}

		if (submitLabel) {
			submitLabel.textContent = config.labels.submitting;
		}

		try {
			const redirectTo = `${window.location.origin}/${config.locale}/auth/reset-password`;
			const result = await authClient.requestPasswordReset({
				email: email.trim(),
				redirectTo,
			});

			if (result.error) {
				const message = mapAuthError('forgot_password', result.error, {
					generic: config.labels.errorGeneric,
					suspended: config.labels.errorGeneric,
					invalidCredentials: config.labels.errorGeneric,
					duplicateEmail: config.labels.errorGeneric,
					rateLimited: config.labels.errorRateLimited,
				});

				if (result.error.status === 429) {
					if (errorText) {
						errorText.textContent = message;
					}
					errorBox?.classList.remove('hidden');
					return;
				}
			}

			if (successText) {
				successText.textContent = config.labels.success;
			}

			successBox?.classList.remove('hidden');
			form.reset();
		} catch {
			if (successText) {
				successText.textContent = config.labels.success;
			}

			successBox?.classList.remove('hidden');
			form.reset();
		} finally {
			if (submitButton) {
				submitButton.disabled = false;
			}

			if (submitLabel) {
				submitLabel.textContent = config.labels.submit;
			}
		}
	});
</script>

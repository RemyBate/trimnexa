---
import Alert from '@/components/common/Alert.astro';
import Button from '@/components/common/Button.astro';
import type { CustomerProfileView } from '@/lib/account/profile';

interface Labels {
	firstName: string;
	lastName: string;
	email: string;
	phone: string;
	locale: string;
	localeEn: string;
	localeFr: string;
	save: string;
	saving: string;
	success: string;
	errorGeneric: string;
}

interface Props {
	profile: CustomerProfileView;
	labels: Labels;
}

const { profile, labels } = Astro.props;
const formConfig = JSON.stringify({ labels });
---

<div id="profile-form-success" class="mb-4 hidden" role="status">
	<Alert variant="success">
		<span id="profile-form-success-text">{labels.success}</span>
	</Alert>
</div>

<div id="profile-form-error" class="mb-4 hidden" role="alert">
	<Alert variant="error">
		<span id="profile-form-error-text">{labels.errorGeneric}</span>
	</Alert>
</div>

<form id="profile-form" class="space-y-4" data-config={formConfig} novalidate>
	<div>
		<label for="profile-email" class="mb-1 block text-sm font-medium text-neutral-800">
			{labels.email}
		</label>
		<input
			id="profile-email"
			type="email"
			value={profile.email}
			disabled
			class="block w-full cursor-not-allowed rounded-md border border-neutral-200 bg-neutral-100 px-3 py-2 text-sm text-neutral-600"
		/>
	</div>
	<div class="grid gap-4 sm:grid-cols-2">
		<div>
			<label for="profile-first-name" class="mb-1 block text-sm font-medium text-neutral-800">
				{labels.firstName}
			</label>
			<input
				id="profile-first-name"
				name="firstName"
				type="text"
				required
				value={profile.firstName ?? ''}
				class="block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200"
			/>
		</div>
		<div>
			<label for="profile-last-name" class="mb-1 block text-sm font-medium text-neutral-800">
				{labels.lastName}
			</label>
			<input
				id="profile-last-name"
				name="lastName"
				type="text"
				value={profile.lastName ?? ''}
				class="block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200"
			/>
		</div>
	</div>
	<div>
		<label for="profile-phone" class="mb-1 block text-sm font-medium text-neutral-800">
			{labels.phone}
		</label>
		<input
			id="profile-phone"
			name="phone"
			type="tel"
			value={profile.phone ?? ''}
			autocomplete="tel"
			class="block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200"
		/>
	</div>
	<div>
		<label for="profile-locale" class="mb-1 block text-sm font-medium text-neutral-800">
			{labels.locale}
		</label>
		<select
			id="profile-locale"
			name="locale"
			class="block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-900 shadow-sm focus:border-primary-600 focus:outline-none focus:ring-2 focus:ring-primary-200"
		>
			<option value="en" selected={profile.locale === 'en'}>{labels.localeEn}</option>
			<option value="fr" selected={profile.locale === 'fr'}>{labels.localeFr}</option>
		</select>
	</div>
	<Button type="submit" id="profile-submit">
		<span id="profile-submit-label">{labels.save}</span>
	</Button>
</form>

<script>
	const form = document.getElementById('profile-form') as HTMLFormElement | null;
	if (!form) {
		throw new Error('Profile form not found');
	}

	const config = JSON.parse(form.dataset.config ?? '{}') as {
		labels: { save: string; saving: string; errorGeneric: string };
	};

	const successBox = document.getElementById('profile-form-success');
	const errorBox = document.getElementById('profile-form-error');
	const submitButton = document.getElementById('profile-submit') as HTMLButtonElement | null;
	const submitLabel = document.getElementById('profile-submit-label');

	form.addEventListener('submit', async (event) => {
		event.preventDefault();
		errorBox?.classList.add('hidden');
		successBox?.classList.add('hidden');

		if (submitButton) {
			submitButton.disabled = true;
		}
		if (submitLabel) {
			submitLabel.textContent = config.labels.saving;
		}

		const formData = new FormData(form);
		const payload = {
			firstName: String(formData.get('firstName') ?? ''),
			lastName: String(formData.get('lastName') ?? ''),
			phone: String(formData.get('phone') ?? ''),
			locale: String(formData.get('locale') ?? 'en'),
		};

		try {
			const response = await fetch('/api/account/profile', {
				method: 'PATCH',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});

			if (!response.ok) {
				errorBox?.classList.remove('hidden');
				return;
			}

			successBox?.classList.remove('hidden');
		} catch {
			errorBox?.classList.remove('hidden');
		} finally {
			if (submitButton) {
				submitButton.disabled = false;
			}
			if (submitLabel) {
				submitLabel.textContent = config.labels.save;
			}
		}
	});
</script>

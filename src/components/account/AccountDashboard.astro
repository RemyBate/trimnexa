---
import { getUserFirstName } from '@/lib/auth/display-name';
import { localizedPath } from '@/i18n';
import type { SupportedLocale } from '@/config/site';
import Card from '@/components/common/Card.astro';
import type { AccountSummary } from '@/lib/account/summary';

interface SessionUser {
	email: string;
	name?: string | null;
	firstName?: string | null;
}

interface DashboardLabels {
	welcomeBack: string;
	signedInAs: string;
	overview: string;
	myProfile: string;
	myOrders: string;
	savedAddresses: string;
	wishlist: string;
	notifications: string;
	support: string;
	manage: string;
	items: string;
	unread: string;
	openTickets: string;
}

interface DashboardLink {
	href: string;
	title: string;
	description: string;
	stat?: string;
}

interface Props {
	locale: SupportedLocale;
	user: SessionUser;
	summary: AccountSummary;
	labels: DashboardLabels;
}

const { locale, user, summary, labels } = Astro.props;
const firstName = getUserFirstName(user);

const links: DashboardLink[] = [
	{
		href: '/account/profile',
		title: labels.myProfile,
		description: labels.manage,
	},
	{
		href: '/account/orders',
		title: labels.myOrders,
		description: `${summary.orderCount} ${labels.items}`,
	},
	{
		href: '/account/addresses',
		title: labels.savedAddresses,
		description: `${summary.addressCount} ${labels.items}`,
	},
	{
		href: '/account/wishlist',
		title: labels.wishlist,
		description: `${summary.wishlistCount} ${labels.items}`,
	},
	{
		href: '/account/notifications',
		title: labels.notifications,
		description: `${summary.unreadNotifications} ${labels.unread}`,
	},
	{
		href: '/account/support',
		title: labels.support,
		description: `${summary.openSupportTickets} ${labels.openTickets}`,
	},
];
---

<section class="space-y-8">
	<div>
		<p class="text-sm font-medium uppercase tracking-wide text-primary-700">{labels.welcomeBack}</p>
		<h2 class="mt-1 text-3xl font-bold text-neutral-900 sm:text-4xl">{firstName}</h2>
		<p class="mt-4 text-sm text-neutral-600">{labels.signedInAs}</p>
		<p class="mt-1 font-medium text-neutral-900">{user.email}</p>
	</div>

	<div>
		<h3 class="mb-4 text-lg font-semibold text-neutral-900">{labels.overview}</h3>
		<div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
			{
				links.map((link) => (
					<a
						href={localizedPath(locale, link.href)}
						class="group block rounded-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
					>
						<Card class="h-full p-5 transition group-hover:border-primary-200 group-hover:shadow-md sm:p-6">
							<h4 class="text-lg font-semibold text-neutral-900 group-hover:text-primary-800">
								{link.title}
							</h4>
							<p class="mt-2 text-sm text-neutral-600">{link.description}</p>
						</Card>
					</a>
				))
			}
		</div>
	</div>
</section>

---
import type { NotificationView } from '@/lib/account/notifications';
import Card from '@/components/common/Card.astro';

interface Labels {
	markRead: string;
	unread: string;
}

interface Props {
	notifications: NotificationView[];
	labels: Labels;
}

const { notifications, labels } = Astro.props;
---

<div class="space-y-4" data-notification-list>
	{
		notifications.map((notification) => (
			<Card class:list={['p-5', !notification.readAt ? 'border-primary-200 bg-primary-50/40' : '']}>
				<div class="flex flex-wrap items-start justify-between gap-3">
					<div>
						<div class="flex items-center gap-2">
							<h3 class="font-semibold text-neutral-900">{notification.title}</h3>
							{!notification.readAt ? (
								<span class="rounded-full bg-primary-100 px-2 py-0.5 text-xs font-medium text-primary-800">
									{labels.unread}
								</span>
							) : null}
						</div>
						<p class="mt-2 text-sm text-neutral-700">{notification.body}</p>
						<p class="mt-2 text-xs text-neutral-500">{notification.createdAt.toLocaleString()}</p>
					</div>
					{!notification.readAt ? (
						<button
							type="button"
							class="notification-read rounded-md px-3 py-1.5 text-sm font-medium text-primary-700 hover:bg-primary-50"
							data-id={notification.id}
						>
							{labels.markRead}
						</button>
					) : null}
				</div>
			</Card>
		))
	}
</div>

<script>
	for (const button of document.querySelectorAll<HTMLButtonElement>('.notification-read')) {
		button.addEventListener('click', async () => {
			const id = button.dataset.id;
			if (!id) {
				return;
			}

			const response = await fetch(`/api/account/notifications/${id}/read`, { method: 'POST' });
			if (response.ok) {
				window.location.reload();
			}
		});
	}
</script>

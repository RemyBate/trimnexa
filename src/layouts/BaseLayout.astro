---
import '@/styles/global.css';
import SeoHead from '@/components/layout/SeoHead.astro';
import { site } from '@/config/site';
import { createPageMetadata } from '@/seo/metadata';
import type { PageMetadata, SeoOptions } from '@/types/seo';

interface Props {
	seo?: SeoOptions | PageMetadata;
	lang?: string;
	class?: string;
}

const { seo: seoInput, lang = site.defaultLocale, class: className } = Astro.props;

const metadata: PageMetadata =
	seoInput && 'openGraph' in seoInput ? seoInput : createPageMetadata(seoInput ?? {});
---

<!doctype html>
<html lang={lang}>
	<head>
		<SeoHead metadata={metadata} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
	</head>
	<body class:list={['min-h-screen bg-neutral-50 text-neutral-900 antialiased', className]}>
		<slot />
	</body>
</html>

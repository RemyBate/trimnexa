---
import type { SupportedLocale } from '@/config/site';
import type { PageContext } from '@/i18n';
import { getOpenGraphLocale } from '@/i18n';
import { createPageMetadata } from '@/seo/metadata';
import type { PageMetadata, SeoOptions } from '@/types/seo';
import BaseLayout from '@/layouts/BaseLayout.astro';
import AnnouncementBar from '@/components/layout/AnnouncementBar.astro';
import CategoryNav from '@/components/layout/CategoryNav.astro';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import SkipLink from '@/components/layout/SkipLink.astro';
import { isDatabaseConfigured } from '@/lib/db';
import { getUserSellerMenuState } from '@/lib/seller/guards';
import { readGuestCartToken } from '@/lib/cart/guest-cookie';
import { countCartItemsForGuest, countCartItemsForUser } from '@/lib/cart/service';

interface Props {
	locale: SupportedLocale;
	currentPath: string;
	t: PageContext['t'];
	seo?: SeoOptions | PageMetadata;
	class?: string;
	showCategoryNav?: boolean;
}

const {
	locale,
	currentPath,
	t,
	seo: seoInput,
	class: className,
	showCategoryNav = true,
} = Astro.props;

const sessionUser = Astro.locals.user;

const sellerMenuState =
	sessionUser && isDatabaseConfigured() ? await getUserSellerMenuState(sessionUser.id) : null;

let cartCount = 0;
if (isDatabaseConfigured()) {
	try {
		if (sessionUser) {
			cartCount = await countCartItemsForUser(sessionUser.id);
		} else {
			const guestToken = readGuestCartToken(Astro.cookies);
			if (guestToken) {
				cartCount = await countCartItemsForGuest(guestToken);
			}
		}
	} catch (error) {
		if (import.meta.env.DEV) {
			console.error('[cart] header count failed', error);
		}
	}
}

const metadata: PageMetadata =
	seoInput && 'openGraph' in seoInput
		? seoInput
		: createPageMetadata({
				...seoInput,
				locale: getOpenGraphLocale(locale),
				path: seoInput?.path ?? currentPath,
			});
---

<BaseLayout lang={locale} seo={metadata} class={className}>
	<SkipLink>{t('common.skipToContent')}</SkipLink>
	<div class="flex min-h-screen flex-col">
		<AnnouncementBar>{t('announcement.message')}</AnnouncementBar>
		<Header
			locale={locale}
			currentPath={currentPath}
			t={t}
			user={sessionUser}
			sellerMenuState={sellerMenuState}
			cartCount={cartCount}
		/>
		{showCategoryNav && <CategoryNav locale={locale} t={t} />}
		<main id="main-content" class="flex-1 focus:outline-none" tabindex="-1">
			<slot />
		</main>
		<Footer locale={locale} t={t} />
	</div>
</BaseLayout>

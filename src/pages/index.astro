---
import Alert from '@/components/common/Alert.astro';
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { createPageMetadata } from '@/seo/metadata';
---

<BaseLayout seo={createPageMetadata({ path: '/' })}>
	<Container class="py-16">
		<main class="mx-auto max-w-xl space-y-6 text-center">
			<h1 class="text-4xl font-bold text-primary-800">Trimnexa</h1>
			<p class="text-lg text-neutral-600">
				Technical foundation complete. Public website and brand identity begin in Phase 2.
			</p>
			<Alert variant="info" title="Development status">
				Milestone 1 complete — no marketplace business logic yet.
			</Alert>
			<div class="flex justify-center gap-3">
				<Button href="/">Home</Button>
				<Button variant="secondary" href="https://docs.astro.build" target="_blank" rel="noopener">
					Astro docs
				</Button>
			</div>
		</main>
	</Container>
</BaseLayout>

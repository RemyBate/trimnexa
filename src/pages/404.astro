---
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { createPageMetadata } from '@/seo/metadata';
---

<BaseLayout seo={createPageMetadata({ title: 'Page not found', path: '/404', noindex: true })}>
	<Container class="flex min-h-[60vh] flex-col items-center justify-center py-16 text-center">
		<p class="text-sm font-medium text-primary-600">404</p>
		<h1 class="mt-2 text-3xl font-bold text-neutral-900">Page not found</h1>
		<p class="mt-4 max-w-md text-neutral-600">
			The page you are looking for does not exist or may have been moved.
		</p>
		<div class="mt-8">
			<Button href="/">Return home</Button>
		</div>
	</Container>
</BaseLayout>

---
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import { site } from '@/config/site';
import { getDictionary } from '@/i18n';
import { createPageMetadata } from '@/seo/metadata';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = true;

const locale = site.defaultLocale;
const dictionary = getDictionary(locale);
const t = (key: string) => {
	const segments = key.split('.');
	let current: unknown = dictionary;
	for (const segment of segments) {
		if (typeof current !== 'object' || current === null || !(segment in current)) return key;
		current = (current as Record<string, unknown>)[segment];
	}
	return typeof current === 'string' ? current : key;
};
---

<BaseLayout
	lang={locale}
	seo={createPageMetadata({ title: t('errors.notFoundTitle'), path: '/404', noindex: true })}
>
	<Container class="flex min-h-[60vh] flex-col items-center justify-center py-16 text-center">
		<p class="text-sm font-medium text-primary-600">404</p>
		<h1 class="mt-2 text-3xl font-bold text-neutral-900">{t('errors.notFoundTitle')}</h1>
		<p class="mt-4 max-w-md text-neutral-600">{t('errors.notFoundMessage')}</p>
		<div class="mt-8">
			<Button href={`/${locale}/`}>{t('errors.returnHome')}</Button>
		</div>
	</Container>
</BaseLayout>

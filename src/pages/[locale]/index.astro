---
import CategoryTiles from '@/components/home/CategoryTiles.astro';
import HeroSection from '@/components/home/HeroSection.astro';
import ProductShowcase from '@/components/home/ProductShowcase.astro';
import SellerCtaSection from '@/components/home/SellerCtaSection.astro';
import TrustSection from '@/components/home/TrustSection.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import { listFeaturedProducts } from '@/lib/catalogue/products';
import PublicLayout from '@/layouts/PublicLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
const featuredProducts = await listFeaturedProducts(locale, 8);
---

<PublicLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('home.metaTitle'),
		t('home.metaDescription'),
	)}
>
	<HeroSection locale={locale} t={t} />
	<CategoryTiles locale={locale} t={t} />
	<ProductShowcase
		locale={locale}
		title={t('home.newProducts')}
		products={featuredProducts}
		t={t}
		viewAllHref={localizedPath(locale, '/products')}
	/>
	<TrustSection t={t} />
	<SellerCtaSection locale={locale} t={t} />
</PublicLayout>

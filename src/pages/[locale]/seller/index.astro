---
import SellerDashboard from '@/components/seller/SellerDashboard.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import { getSellerNavItems } from '@/lib/seller/navigation';
import { getSellerProfileByUserId } from '@/lib/seller/profile';
import { requireApprovedSeller } from '@/lib/seller/guards';
import { getSellerDashboardSummary } from '@/lib/seller/summary';
import SellerLayout from '@/layouts/SellerLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
await requireApprovedSeller(Astro, locale);

const summary = await getSellerDashboardSummary(Astro.locals.user!.id);
const profile = await getSellerProfileByUserId(Astro.locals.user!.id);
const navItems = getSellerNavItems(t);

if (!summary || !profile) {
	return Astro.redirect(localizedPath(locale, '/seller/application'));
}
---

<SellerLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	title={t('seller.dashboardTitle')}
	navItems={navItems}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('seller.dashboardTitle'),
		t('seller.dashboardDescription'),
		{ noindex: true },
	)}
>
	<SellerDashboard
		locale={locale}
		summary={summary}
		labels={{
			welcome: t('seller.welcome'),
			shopLabel: t('seller.shopLabel'),
			onboardingTitle: t('seller.onboardingTitle'),
			onboardingDescription: t('seller.onboardingDescription'),
			completeOnboarding: t('seller.completeOnboarding'),
			completing: t('seller.completing'),
			onboardingDone: t('seller.onboardingDone'),
			manageShop: t('seller.manageShop'),
			productsSoon: t('seller.productsSoon'),
			ordersSoon: t('seller.ordersSoon'),
			checklistShop: t('seller.checklistShop'),
			checklistAddress: t('seller.checklistAddress'),
			checklistLogo: t('seller.checklistLogo'),
			checklistPolicies: t('seller.checklistPolicies'),
		}}
	/>
</SellerLayout>

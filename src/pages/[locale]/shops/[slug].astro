---
import Container from '@/components/common/Container.astro';
import PageNotFound from '@/components/common/PageNotFound.astro';
import Breadcrumbs from '@/components/catalogue/Breadcrumbs.astro';
import CatalogueToolbar from '@/components/catalogue/CatalogueToolbar.astro';
import Pagination from '@/components/catalogue/Pagination.astro';
import ProductGrid from '@/components/catalogue/ProductGrid.astro';
import Card from '@/components/common/Card.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import { getPublicShopBySlug, listPublicProducts } from '@/lib/catalogue/products';
import { parseCatalogueSearchParams } from '@/lib/catalogue/validation';
import PublicLayout from '@/layouts/PublicLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
const slug = (Astro.params as Record<string, string | undefined>).slug;
const shop = slug ? await getPublicShopBySlug(slug) : null;

if (!shop) {
	Astro.response.status = 404;
}

const parsed = shop ? parseCatalogueSearchParams(Astro.url.searchParams) : null;
const basePath = shop ? localizedPath(locale, `/shops/${shop.shopSlug}`) : '';

const result = shop
	? await listPublicProducts({
			locale,
			page: parsed!.page,
			pageSize: parsed!.pageSize,
			sort: parsed!.sort,
			sellerSlug: shop.shopSlug,
			minPriceMajor: parsed!.minPrice,
			maxPriceMajor: parsed!.maxPrice,
			inStockOnly: parsed!.inStock,
		})
	: null;
---

<PublicLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	seo={shop
		? createLocalizedPageMetadata(
				locale,
				currentPath,
				shop.shopName,
				shop.description ?? t('catalogue.shopDescriptionFallback'),
			)
		: createLocalizedPageMetadata(
				locale,
				currentPath,
				t('catalogue.shopNotFoundTitle'),
				t('catalogue.shopNotFoundMessage'),
				{ noindex: true },
			)}
>
	{
		shop && parsed && result ? (
			<Container class="space-y-6 py-10">
				<Breadcrumbs
					locale={locale}
					items={[
						{ label: t('nav.home'), href: localizedPath(locale, '/') },
						{ label: t('catalogue.shopsTitle'), href: localizedPath(locale, '/shops') },
						{ label: shop.shopName },
					]}
				/>

				<Card class="overflow-hidden p-0">
					<div class="grid gap-0 md:grid-cols-[auto_1fr]">
						<div class="flex items-center justify-center bg-primary-50 p-6">
							{shop.logoUrl ? (
								<img src={shop.logoUrl} alt="" class="h-24 w-24 rounded-md object-cover" />
							) : (
								<div class="flex h-24 w-24 items-center justify-center rounded-md bg-white text-2xl font-bold text-primary-800">
									{shop.shopName.slice(0, 1)}
								</div>
							)}
						</div>
						<div class="space-y-2 p-6">
							<h1 class="text-3xl font-bold text-neutral-900">{shop.shopName}</h1>
							<p class="text-sm text-neutral-600">
								{shop.city ? `${shop.city}${shop.region ? `, ${shop.region}` : ''}` : shop.region}
							</p>
							{shop.description ? <p class="text-neutral-700">{shop.description}</p> : null}
							<p class="text-sm font-medium text-neutral-800">
								{shop.productCount} {t('catalogue.productsLabel')}
							</p>
						</div>
					</div>
				</Card>

				<CatalogueToolbar
					action={basePath}
					query={{
						sort: parsed.sort,
						minPrice: parsed.minPrice,
						maxPrice: parsed.maxPrice,
						inStock: parsed.inStock,
					}}
					labels={{
						sort: t('catalogue.sort'),
						sortNewest: t('catalogue.sortNewest'),
						sortPriceAsc: t('catalogue.sortPriceAsc'),
						sortPriceDesc: t('catalogue.sortPriceDesc'),
						sortTitleAsc: t('catalogue.sortTitleAsc'),
						inStockOnly: t('catalogue.inStockOnly'),
						minPrice: t('catalogue.minPrice'),
						maxPrice: t('catalogue.maxPrice'),
						applyFilters: t('catalogue.applyFilters'),
						resetFilters: t('catalogue.resetFilters'),
					}}
				/>

				<ProductGrid
					locale={locale}
					products={result.items}
					labels={{
						outOfStock: t('catalogue.outOfStock'),
						inStock: t('catalogue.inStock'),
						bySeller: t('catalogue.bySeller'),
						emptyTitle: t('catalogue.emptyShopTitle'),
						emptyDescription: t('catalogue.emptyShopDescription'),
					}}
				/>

				<Pagination
					basePath={basePath}
					query={{
						sort: parsed.sort,
						minPrice: parsed.minPrice?.toString(),
						maxPrice: parsed.maxPrice?.toString(),
						inStock: parsed.inStock ? '1' : undefined,
					}}
					result={result}
					labels={{
						previous: t('catalogue.previousPage'),
						next: t('catalogue.nextPage'),
						page: t('catalogue.page'),
					}}
				/>
			</Container>
		) : (
			<PageNotFound
				locale={locale}
				title={t('catalogue.shopNotFoundTitle')}
				message={t('catalogue.shopNotFoundMessage')}
				homeLabel={t('errors.returnHome')}
			/>
		)
	}
</PublicLayout>

---
import Card from '@/components/common/Card.astro';
import Button from '@/components/common/Button.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import { getAdminNavItems } from '@/lib/admin/navigation';
import { requireRoles } from '@/lib/authz';
import { Role } from '@prisma/client';
import AdminLayout from '@/layouts/AdminLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
await requireRoles(Astro, locale, [Role.ADMINISTRATOR, Role.STAFF]);
const navItems = getAdminNavItems(t);
---

<AdminLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	title={t('admin.dashboardTitle')}
	navItems={navItems}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('admin.dashboardTitle'),
		t('admin.dashboardDescription'),
		{ noindex: true },
	)}
>
	<Card class="p-6 sm:p-8">
		<p class="text-neutral-600">{t('admin.dashboardSubtitle')}</p>
		<Button href={localizedPath(locale, '/admin/sellers')} class="mt-4">
			{t('admin.manageSellers')}
		</Button>
	</Card>
</AdminLayout>

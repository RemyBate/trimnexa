---
import Container from '@/components/common/Container.astro';
import Card from '@/components/common/Card.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale } from '@/i18n';
import { requireRoles } from '@/lib/authz';
import { Role } from '@prisma/client';
import PublicLayout from '@/layouts/PublicLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
await requireRoles(Astro, locale, [Role.ADMINISTRATOR, Role.STAFF]);
---

<PublicLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	showCategoryNav={false}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('admin.dashboardTitle'),
		t('admin.dashboardDescription'),
		{ noindex: true },
	)}
>
	<Container class="py-10">
		<Card class="mx-auto max-w-2xl p-6 sm:p-8">
			<h1 class="text-2xl font-bold text-neutral-900">{t('admin.dashboardTitle')}</h1>
			<p class="mt-2 text-neutral-600">{t('admin.dashboardSubtitle')}</p>
			<p class="mt-4 text-sm text-neutral-500">{t('admin.placeholder')}</p>
		</Card>
	</Container>
</PublicLayout>

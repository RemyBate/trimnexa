---
import Container from '@/components/common/Container.astro';
import Card from '@/components/common/Card.astro';
import EmptyState from '@/components/catalogue/EmptyState.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import { listTopLevelCategories } from '@/lib/catalogue/categories';
import PublicLayout from '@/layouts/PublicLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
const categories = await listTopLevelCategories(locale);

const categoryColors = [
	'from-primary-600 to-primary-800',
	'from-accent-500 to-accent-600',
	'from-info-600 to-primary-700',
	'from-success-600 to-primary-700',
	'from-warning-600 to-accent-600',
	'from-neutral-600 to-primary-800',
];
---

<PublicLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('catalogue.categoriesTitle'),
		t('catalogue.categoriesDescription'),
	)}
>
	<Container class="space-y-8 py-10">
		<div>
			<h1 class="text-3xl font-bold text-neutral-900">{t('catalogue.categoriesTitle')}</h1>
			<p class="mt-2 text-neutral-600">{t('catalogue.categoriesDescription')}</p>
		</div>

		{
			categories.length === 0 ? (
				<EmptyState
					title={t('catalogue.emptyCategoriesTitle')}
					description={t('catalogue.emptyCategoriesDescription')}
				/>
			) : (
				<ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{categories.map((category, index) => (
						<li>
							<a href={localizedPath(locale, `/categories/${category.slug}`)}>
								<Card class="overflow-hidden p-0 transition-shadow hover:shadow-md">
									<div
										class:list={[
											'flex h-28 items-end bg-gradient-to-br p-4 text-white',
											categoryColors[index % categoryColors.length],
										]}
									>
										<span class="text-lg font-semibold">{category.name}</span>
									</div>
								</Card>
							</a>
						</li>
					))}
				</ul>
			)
		}
	</Container>
</PublicLayout>

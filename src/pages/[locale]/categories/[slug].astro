---
import Container from '@/components/common/Container.astro';
import PageNotFound from '@/components/common/PageNotFound.astro';
import Breadcrumbs from '@/components/catalogue/Breadcrumbs.astro';
import CatalogueToolbar from '@/components/catalogue/CatalogueToolbar.astro';
import Pagination from '@/components/catalogue/Pagination.astro';
import ProductGrid from '@/components/catalogue/ProductGrid.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import { getPublicCategoryBySlug } from '@/lib/catalogue/categories';
import { listPublicProducts } from '@/lib/catalogue/products';
import { parseCatalogueSearchParams } from '@/lib/catalogue/validation';
import PublicLayout from '@/layouts/PublicLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
const slug = (Astro.params as Record<string, string | undefined>).slug;
const category = slug ? await getPublicCategoryBySlug(slug, locale) : null;

if (!category) {
	Astro.response.status = 404;
}

const parsed = category ? parseCatalogueSearchParams(Astro.url.searchParams) : null;
const basePath = category ? localizedPath(locale, `/categories/${category.slug}`) : '';

const result = category
	? await listPublicProducts({
			locale,
			page: parsed!.page,
			pageSize: parsed!.pageSize,
			sort: parsed!.sort,
			categorySlug: category.slug,
			minPriceMajor: parsed!.minPrice,
			maxPriceMajor: parsed!.maxPrice,
			inStockOnly: parsed!.inStock,
		})
	: null;
---

<PublicLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	seo={category
		? createLocalizedPageMetadata(
				locale,
				currentPath,
				category.name,
				category.description ?? t('catalogue.categoryDescriptionFallback'),
			)
		: createLocalizedPageMetadata(
				locale,
				currentPath,
				t('catalogue.categoryNotFoundTitle'),
				t('catalogue.categoryNotFoundMessage'),
				{ noindex: true },
			)}
>
	{
		category && parsed && result ? (
			<Container class="space-y-6 py-10">
				<Breadcrumbs
					locale={locale}
					items={category.breadcrumbs.map((crumb, index, items) => ({
						label:
							crumb.label === 'home'
								? t('nav.home')
								: crumb.label === 'catalogue'
									? t('catalogue.productsTitle')
									: crumb.label,
						href: index < items.length - 1 ? crumb.href : undefined,
					}))}
				/>

				<div>
					<h1 class="text-3xl font-bold text-neutral-900">{category.name}</h1>
					{category.description ? (
						<p class="mt-2 text-neutral-600">{category.description}</p>
					) : null}
				</div>

				{category.children.length > 0 ? (
					<div class="flex flex-wrap gap-2">
						{category.children.map((child) => (
							<a
								href={localizedPath(locale, `/categories/${child.slug}`)}
								class="rounded-full border border-neutral-300 bg-white px-3 py-1 text-sm font-medium text-neutral-800 hover:border-primary-400 hover:text-primary-800"
							>
								{child.name}
							</a>
						))}
					</div>
				) : null}

				<CatalogueToolbar
					action={basePath}
					query={{
						sort: parsed.sort,
						minPrice: parsed.minPrice,
						maxPrice: parsed.maxPrice,
						inStock: parsed.inStock,
					}}
					labels={{
						sort: t('catalogue.sort'),
						sortNewest: t('catalogue.sortNewest'),
						sortPriceAsc: t('catalogue.sortPriceAsc'),
						sortPriceDesc: t('catalogue.sortPriceDesc'),
						sortTitleAsc: t('catalogue.sortTitleAsc'),
						inStockOnly: t('catalogue.inStockOnly'),
						minPrice: t('catalogue.minPrice'),
						maxPrice: t('catalogue.maxPrice'),
						applyFilters: t('catalogue.applyFilters'),
						resetFilters: t('catalogue.resetFilters'),
					}}
				/>

				<p class="text-sm text-neutral-600">
					{result.totalItems} {t('catalogue.resultsLabel')}
				</p>

				<ProductGrid
					locale={locale}
					products={result.items}
					labels={{
						outOfStock: t('catalogue.outOfStock'),
						inStock: t('catalogue.inStock'),
						bySeller: t('catalogue.bySeller'),
						emptyTitle: t('catalogue.emptyCategoryTitle'),
						emptyDescription: t('catalogue.emptyCategoryDescription'),
					}}
				/>

				<Pagination
					basePath={basePath}
					query={{
						sort: parsed.sort,
						minPrice: parsed.minPrice?.toString(),
						maxPrice: parsed.maxPrice?.toString(),
						inStock: parsed.inStock ? '1' : undefined,
					}}
					result={result}
					labels={{
						previous: t('catalogue.previousPage'),
						next: t('catalogue.nextPage'),
						page: t('catalogue.page'),
					}}
				/>
			</Container>
		) : (
			<PageNotFound
				locale={locale}
				title={t('catalogue.categoryNotFoundTitle')}
				message={t('catalogue.categoryNotFoundMessage')}
				homeLabel={t('errors.returnHome')}
			/>
		)
	}
</PublicLayout>

---
import Card from '@/components/common/Card.astro';
import ProfileForm from '@/components/account/ProfileForm.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import { getCustomerProfile } from '@/lib/account/profile';
import { getAccountNavItems } from '@/lib/account/navigation';
import { requireSessionUser } from '@/lib/authz';
import AccountLayout from '@/layouts/AccountLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
const marketplaceUser = await requireSessionUser(Astro, locale);
const profile = await getCustomerProfile(marketplaceUser.id);

if (!profile) {
	return Astro.redirect(localizedPath(locale, '/auth/login'));
}

const navItems = getAccountNavItems(t);
---

<AccountLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	title={t('account.profileTitle')}
	navItems={navItems}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('account.profileTitle'),
		t('account.profileDescription'),
		{ noindex: true },
	)}
>
	<Card class="p-5 sm:p-6">
		<ProfileForm
			profile={profile}
			labels={{
				firstName: t('auth.firstName'),
				lastName: t('auth.lastName'),
				email: t('auth.email'),
				phone: t('account.phone'),
				locale: t('common.language'),
				localeEn: 'English',
				localeFr: 'Français',
				save: t('account.saveChanges'),
				saving: t('auth.submitting'),
				success: t('account.profileSaved'),
				errorGeneric: t('auth.errorGeneric'),
			}}
		/>
	</Card>
</AccountLayout>

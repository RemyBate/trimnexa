---
import AccountEmptyState from '@/components/account/AccountEmptyState.astro';
import NotificationList from '@/components/account/NotificationList.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale } from '@/i18n';
import { listNotifications } from '@/lib/account/notifications';
import { getAccountNavItems } from '@/lib/account/navigation';
import { requireSessionUser } from '@/lib/authz';
import AccountLayout from '@/layouts/AccountLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
const marketplaceUser = await requireSessionUser(Astro, locale);
const notifications = await listNotifications(marketplaceUser.id);
const navItems = getAccountNavItems(t);
---

<AccountLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	title={t('account.notificationsTitle')}
	navItems={navItems}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('account.notificationsTitle'),
		t('account.notificationsDescription'),
		{ noindex: true },
	)}
>
	{
		notifications.length === 0 ? (
			<AccountEmptyState
				title={t('account.noNotificationsTitle')}
				description={t('account.noNotificationsDescription')}
			/>
		) : (
			<NotificationList
				notifications={notifications}
				labels={{
					markRead: t('account.markRead'),
					unread: t('account.unread'),
				}}
			/>
		)
	}
</AccountLayout>

---
import Alert from '@/components/common/Alert.astro';
import AccountDashboard from '@/components/account/AccountDashboard.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import { formatWelcomeMessage, getUserFirstName } from '@/lib/auth/display-name';
import { getAccountNavItems } from '@/lib/account/navigation';
import { getAccountSummary } from '@/lib/account/summary';
import { requireSessionUser } from '@/lib/authz';
import AccountLayout from '@/layouts/AccountLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
const marketplaceUser = await requireSessionUser(Astro, locale);
const sessionUser = Astro.locals.user;

if (!sessionUser) {
	return Astro.redirect(localizedPath(locale, '/auth/login'));
}

const summary = await getAccountSummary(marketplaceUser.id);
const navItems = getAccountNavItems(t);
const showWelcome = Astro.url.searchParams.get('welcome') === '1';
const welcomeMessage = showWelcome
	? formatWelcomeMessage(t('account.welcomeMessage'), getUserFirstName(sessionUser))
	: undefined;
---

<AccountLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	title={t('account.dashboardTitle')}
	navItems={navItems}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('account.dashboardTitle'),
		t('account.dashboardDescription'),
		{ noindex: true },
	)}
>
	{
		welcomeMessage ? (
			<Alert variant="success" class="mb-6">
				{welcomeMessage}
			</Alert>
		) : null
	}
	<AccountDashboard
		locale={locale}
		user={sessionUser}
		summary={summary}
		labels={{
			welcomeBack: t('account.welcomeBack'),
			signedInAs: t('account.signedInAs'),
			overview: t('account.overview'),
			myProfile: t('account.myProfile'),
			myOrders: t('account.myOrders'),
			savedAddresses: t('account.savedAddresses'),
			wishlist: t('account.wishlist'),
			notifications: t('account.nav.notifications'),
			support: t('account.nav.support'),
			manage: t('account.manage'),
			items: t('account.items'),
			unread: t('account.unread'),
			openTickets: t('account.openTickets'),
		}}
	/>
</AccountLayout>

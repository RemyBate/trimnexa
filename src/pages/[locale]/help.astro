---
import Container from '@/components/common/Container.astro';
import Card from '@/components/common/Card.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale } from '@/i18n';
import PublicLayout from '@/layouts/PublicLayout.astro';

export const prerender = true;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;

const topics = [
	{ titleKey: 'help.topicOrders', descKey: 'help.topicOrdersDesc' },
	{ titleKey: 'help.topicPayments', descKey: 'help.topicPaymentsDesc' },
	{ titleKey: 'help.topicReturns', descKey: 'help.topicReturnsDesc' },
	{ titleKey: 'help.topicSelling', descKey: 'help.topicSellingDesc' },
];
---

<PublicLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	showCategoryNav={false}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('help.metaTitle'),
		t('help.metaDescription'),
	)}
>
	<Container class="py-12 sm:py-16">
		<div class="mx-auto max-w-4xl space-y-8">
			<header class="space-y-3">
				<h1 class="text-4xl font-bold text-neutral-900">{t('help.title')}</h1>
				<p class="text-lg text-neutral-600">{t('help.intro')}</p>
			</header>
			<ul class="grid gap-4 sm:grid-cols-2">
				{
					topics.map((topic) => (
						<li>
							<Card>
								<h2 class="font-semibold text-primary-800">{t(topic.titleKey)}</h2>
								<p class="mt-2 text-sm text-neutral-600">{t(topic.descKey)}</p>
							</Card>
						</li>
					))
				}
			</ul>
		</div>
	</Container>
</PublicLayout>

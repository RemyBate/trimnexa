---
import ForgotPasswordForm from '@/components/auth/ForgotPasswordForm.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import AuthLayout from '@/layouts/AuthLayout.astro';
import PublicLayout from '@/layouts/PublicLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
---

<PublicLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	showCategoryNav={false}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('auth.forgotPasswordTitle'),
		t('auth.forgotPasswordDescription'),
		{ noindex: true },
	)}
>
	<AuthLayout title={t('auth.forgotPasswordTitle')} subtitle={t('auth.forgotPasswordSubtitle')}>
		<ForgotPasswordForm
			locale={locale}
			labels={{
				email: t('auth.email'),
				submit: t('auth.resetRequestSubmit'),
				submitting: t('auth.submitting'),
				success: t('auth.resetRequestSuccess'),
				errorGeneric: t('auth.errorGeneric'),
				errorEmailRequired: t('auth.errorEmailRequired'),
				errorEmailInvalid: t('auth.errorEmailInvalid'),
			}}
		/>
		<Fragment slot="footer">
			<a
				href={localizedPath(locale, '/auth/login')}
				class="font-medium text-primary-700 hover:text-primary-800"
			>
				{t('auth.backToLogin')}
			</a>
		</Fragment>
	</AuthLayout>
</PublicLayout>

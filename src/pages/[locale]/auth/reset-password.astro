---
import ResetPasswordForm from '@/components/auth/ResetPasswordForm.astro';
import { createLocalizedPageMetadata } from '@/i18n/page-metadata';
import { getPageContext, getStaticPathsForLocale, localizedPath } from '@/i18n';
import AuthLayout from '@/layouts/AuthLayout.astro';
import PublicLayout from '@/layouts/PublicLayout.astro';

export const prerender = false;
export const getStaticPaths = getStaticPathsForLocale;

const { locale, t } = getPageContext(Astro);
const currentPath = Astro.url.pathname;
---

<PublicLayout
	locale={locale}
	currentPath={currentPath}
	t={t}
	showCategoryNav={false}
	seo={createLocalizedPageMetadata(
		locale,
		currentPath,
		t('auth.resetPasswordTitle'),
		t('auth.resetPasswordDescription'),
		{ noindex: true },
	)}
>
	<AuthLayout title={t('auth.resetPasswordTitle')} subtitle={t('auth.resetPasswordSubtitle')}>
		<ResetPasswordForm
			loginPath={localizedPath(locale, '/auth/login')}
			labels={{
				password: t('auth.newPassword'),
				confirmPassword: t('auth.confirmPassword'),
				passwordHint: t('auth.passwordHint'),
				showPassword: t('auth.showPassword'),
				hidePassword: t('auth.hidePassword'),
				submit: t('auth.resetPasswordSubmit'),
				submitting: t('auth.submitting'),
				success: t('auth.resetPasswordSuccess'),
				errorGeneric: t('auth.errorGeneric'),
				errorMismatch: t('auth.passwordMismatch'),
				errorMissingToken: t('auth.missingResetToken'),
				errorPasswordRequired: t('auth.errorPasswordRequired'),
				errorPasswordTooShort: t('auth.errorPasswordTooShort'),
				errorConfirmRequired: t('auth.errorConfirmRequired'),
			}}
		/>
	</AuthLayout>
</PublicLayout>

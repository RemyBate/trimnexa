---
import Button from '@/components/common/Button.astro';
import Container from '@/components/common/Container.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { createPageMetadata } from '@/seo/metadata';
---

<BaseLayout seo={createPageMetadata({ title: 'Server error', path: '/500', noindex: true })}>
	<Container class="flex min-h-[60vh] flex-col items-center justify-center py-16 text-center">
		<p class="text-sm font-medium text-error-600">500</p>
		<h1 class="mt-2 text-3xl font-bold text-neutral-900">Something went wrong</h1>
		<p class="mt-4 max-w-md text-neutral-600">
			An unexpected error occurred. Please try again later or return to the homepage.
		</p>
		<div class="mt-8">
			<Button href="/">Return home</Button>
		</div>
	</Container>
</BaseLayout>
